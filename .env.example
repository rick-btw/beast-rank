# Local development uses SQLite by default.
DATABASE_URL="file:./dev.db"

# Example admin login.
ADMIN_EMAIL="admin@beastrank.local"
ADMIN_PASSWORD="monsteradmin"

# Use a long random string in production.
AUTH_SECRET="replace-with-a-long-random-secret"

# Optional production hardening. If set, this takes precedence over ADMIN_PASSWORD.
# Generate with: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
# ADMIN_PASSWORD_HASH=""
